<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/Theme.NeuralNetBuilder.Toolbar"
        app:title="Tutorials"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <!-- Chapter tabs (horizontal scroll) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chapterRecycler"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_card"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:clipToPadding="false"/>

    <!-- Chapter title -->
    <TextView
        android:id="@+id/chapterTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chapter Title"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"/>

    <!-- Page ViewPager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Navigation footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/surface_card">

        <Button
            android:id="@+id/prevBtn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="← Prev"
            style="@style/Widget.NeuralNet.Button.Secondary"/>

        <TextView
            android:id="@+id/pageIndicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 / 1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/nextBtn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Next →"
            style="@style/Widget.NeuralNet.Button.Primary"/>
    </LinearLayout>

</LinearLayout>
