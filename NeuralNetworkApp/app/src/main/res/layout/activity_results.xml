<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/Theme.NeuralNetBuilder.Toolbar"
        app:title="Results"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Eval metrics -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 Final Metrics"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:id="@+id/evalLossText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Validation Loss: —" android:textColor="@color/chart_val"
                        android:textSize="14sp" android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                    <TextView android:id="@+id/evalAccText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Validation Accuracy: —" android:textColor="@color/chart_acc_train"
                        android:textSize="14sp" android:fontFamily="monospace" android:layout_marginBottom="4dp"
                        android:visibility="gone"/>

                    <TextView android:id="@+id/bestLossText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Best Train Loss: —" android:textColor="@color/chart_train"
                        android:textSize="14sp" android:fontFamily="monospace" android:layout_marginBottom="4dp"/>

                    <TextView android:id="@+id/finalLossText"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Final Train Loss: —" android:textColor="@color/text_secondary"
                        android:textSize="14sp" android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sample predictions -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍 Sample Predictions"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/samplePredsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:lineSpacingMultiplier="1.4"/>
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Network summary -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏗️ Network Architecture"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/summaryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Manual prediction -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ Try a Prediction"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/predictionHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Enter comma-separated feature values:"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:hint="e.g. 0.5, 1.2, 0.8"
                        android:layout_marginBottom="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/predictionInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textColor="@color/text_primary"
                            android:fontFamily="monospace"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/predictBtn"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Predict →"
                        style="@style/Widget.NeuralNet.Button.Primary"/>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.NeuralNet.Card.Highlighted"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"
                        android:id="@+id/resultContainer">

                        <TextView
                            android:id="@+id/predictionResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/brand_accent"
                            android:textSize="15sp"
                            android:fontFamily="monospace"
                            android:padding="12dp"/>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
