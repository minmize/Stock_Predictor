<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/Theme.NeuralNetBuilder.Toolbar"
        app:title="Build Network"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Structure text input -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Network Structure"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Type neuron counts separated by dashes.\nExample: 4-64-32-1 means:\n  4 inputs → 64 neurons → 32 neurons → 1 output"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:hintTextColor="@color/brand_accent"
                        android:hint="e.g. 4-64-32-1">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/structureInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textColor="@color/text_primary"
                            android:fontFamily="monospace"
                            android:textSize="18sp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/parseError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/error"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>

                    <!-- Example chips -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick examples:"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/exampleChips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip2class"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Binary"
                            style="@style/Widget.NeuralNet.Chip"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMulti"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Multi-class"
                            style="@style/Widget.NeuralNet.Chip"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRegress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Regression"
                            style="@style/Widget.NeuralNet.Chip"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipDeep"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Deep"
                            style="@style/Widget.NeuralNet.Chip"/>
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Layer cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Layers (drag to reorder hidden layers)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>

                <Button
                    android:id="@+id/addLayerBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+ Layer"
                    style="@style/Widget.NeuralNet.Button.Secondary"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/layerRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/layerCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Layers: —"
                    android:textColor="@color/brand_accent"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/paramCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parameters: —"
                    android:textColor="@color/brand_accent"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Training hyperparameters -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Training Settings"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp"/>

                    <!-- Loss function -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:hint="Loss Function"
                        android:layout_marginBottom="10dp">

                        <AutoCompleteTextView
                            android:id="@+id/lossSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- LR, Epochs, Batch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:hint="Learning Rate"
                            android:layout_marginEnd="4dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/lrInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"
                                android:text="0.001"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:hint="Epochs"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/epochsInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/text_primary"
                                android:text="50"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:hint="Batch Size"
                            android:layout_marginStart="4dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/batchInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textColor="@color/text_primary"
                                android:text="32"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:padding="12dp">

        <Button
            android:id="@+id/btnSummary"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="📋 Summary"
            style="@style/Widget.NeuralNet.Button.Secondary"/>

        <Button
            android:id="@+id/nextBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Next: Load Data →"
            style="@style/Widget.NeuralNet.Button.Primary"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
