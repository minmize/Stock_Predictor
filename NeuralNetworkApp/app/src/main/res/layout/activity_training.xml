<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        style="@style/Theme.NeuralNetBuilder.Toolbar"
        app:title="Training"
        app:navigationIcon="@drawable/ic_arrow_back"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Network summary (collapsed) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Network Architecture"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/networkSummaryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Epoch progress -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Epoch "
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/epochProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/brand_accent"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/epochsTotal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="/ 50"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:max="50"
                        android:progress="0"/>

                    <!-- Live metrics -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp">

                        <TextView android:id="@+id/metricTrainLoss"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Train Loss: —" android:textColor="@color/chart_train"
                            android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/metricValLoss"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Val Loss:   —" android:textColor="@color/chart_val"
                            android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/metricTrainAcc"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Train Acc:  —" android:textColor="@color/chart_acc_train"
                            android:textSize="13sp" android:fontFamily="monospace"/>
                        <TextView android:id="@+id/metricValAcc"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Val Acc:    —" android:textColor="@color/chart_acc_val"
                            android:textSize="13sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loss chart -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loss Curve"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lossChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Accuracy chart (classification only) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/accCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accuracy (%)"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/accChart"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Training log -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.NeuralNet.Card"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Training Log"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp"/>

                    <ScrollView
                        android:id="@+id/logScroll"
                        android:layout_width="match_parent"
                        android:layout_height="160dp">

                        <TextView
                            android:id="@+id/logText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:lineSpacingMultiplier="1.3"/>
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_card"
        android:padding="12dp">

        <Button
            android:id="@+id/startBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="▶ Start"
            style="@style/Widget.NeuralNet.Button.Primary"/>

        <Button
            android:id="@+id/stopBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⏹ Stop"
            style="@style/Widget.NeuralNet.Button.Secondary"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/resultsBtn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="📊 Results"
            style="@style/Widget.NeuralNet.Button.Secondary"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
